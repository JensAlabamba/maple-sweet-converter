{
  "name": "converter-magic",
  "private": true,
  "version": "1.0.0",
  "description": "Image converter app workspace",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "serve -l 5500 .",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "serve": "^14.2.4"
  }
}
